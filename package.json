    "express": "^4.19.2",
    "marked": "^12.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "css-select": "^5.1.0",
    "htmlparser2": "^9.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^9.0.0"
